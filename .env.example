# PostgreSQL (Railway u otro proveedor). Formato estándar:
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@HOST:5432/NOMBRE_BD?sslmode=require"

# Acceso privado (obligatorio en producción)
AUTH_USERNAME="tu_usuario"
AUTH_PASSWORD="contraseña_segura"
# Secreto para firmar la cookie de sesión (usa una cadena larga aleatoria, p. ej. openssl rand -base64 32)
AUTH_SECRET="cambia_por_un_secreto_largo_y_aleatorio"

# Opcional: si en el futuro integras subida con Cloudinary, añadirías por ejemplo:
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
