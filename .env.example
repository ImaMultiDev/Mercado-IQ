# PostgreSQL (Railway u otro proveedor). Formato estándar:
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@HOST:5432/NOMBRE_BD?sslmode=require"

# Opcional: si en el futuro integras subida con Cloudinary, añadirías por ejemplo:
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
